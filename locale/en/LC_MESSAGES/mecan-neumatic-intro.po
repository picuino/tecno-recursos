#: ../../source/mecan-neumatic-intro.rst:10
msgid "Introducción a la neumática"
msgstr "Introduction to pneumatics"

#: ../../source/mecan-neumatic-intro.rst:11
msgid ""
"La neumática es la tecnología que emplea el aire comprimido como medio de"
" transmisión de energía para mover mecanismos y máquinas."
msgstr ""
"Pneumatics is the technology that uses compressed air as a means of "
"energy transmission to move mechanisms and machines."

