#: ../../source/taller-tesela-regular.rst:55
msgid "Tesela pez volador"
msgstr ""

#: ../../source/taller-tesela-regular.rst:56
msgid ""
"Esta tesela está basada en un triángulo equilátero. Necesita traslación y"
" rotación para que las diferentes teselas encajen."
msgstr ""

#: ../../source/taller-tesela-regular.rst:64
msgid "Tesela de pez volador."
msgstr ""

#: ../../source/taller-tesela-regular.rst:67
msgid ""
":download:`Teselas de peces voladores. Formato PDF. <taller/taller-"
"tesela-pez-volador.pdf>`"
msgstr ""

